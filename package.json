{
  "name": "avioagent-doc-verifier",
  "version": "1.0.0",
  "description": "Offline Aadhaar & PAN document verification with Tesseract OCR",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "batch": "node scripts/batch-verify.js",
    "mocks": "node scripts/generate-mocks.js",
    "fixtures": "node scripts/generate-fixtures.js",
    "test:extract": "node scripts/batch-extract.js",
    "test:unit": "node --test test/**/*.test.js",
    "test:regression": "node scripts/batch-regression.js",
    "test": "npm run test:unit && npm run test:regression"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.21.2",
    "jsqr": "^1.4.0",
    "multer": "^1.4.5-lts.1",
    "node-poppler": "^10.0.1",
    "pdf-lib": "^1.17.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "sharp": "^0.33.5",
    "tesseract.js": "^5.1.1",
    "uuid": "^11.1.0"
  }
}
